modules = ["dotnet-7.0", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["nasm", "qemu", "gcc-unwrapped", "binutils", "gnumake", "p7zip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && make image && mkdir -p /tmp/xdg-runtime && XDG_RUNTIME_DIR=/tmp/xdg-runtime DISPLAY=:0 qemu-system-i386 -kernel build/ksdos.elf -vga std -display sdl -m 256"
