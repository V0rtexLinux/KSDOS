; =============================================================================
; NTOSKRNL.EXE - NT Operating System Kernel
; Core executive services for KSDOS
; =============================================================================

org 0x1000

; ---- NTOSKRNL header ----
db 'NTKR', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd ntoskrnl_start              ; Entry point
dd ntoskrnl_end - ntoskrnl_start  ; Size
dd 0x00000000                  ; Reserved

ntoskrnl_start:
    ; Executive services initialization
    ret

ntoskrnl_end:
    db 'END', 0, 0, 0         ; End marker
