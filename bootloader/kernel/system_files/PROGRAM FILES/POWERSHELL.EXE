; =============================================================================
; POWERSHELL.EXE - KSDOS PowerShell
; Advanced command shell and scripting environment
; =============================================================================

org 0x1000

; ---- POWERSHELL header ----
db 'PSHL', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd powershell_start            ; Entry point
dd powershell_end - powershell_start  ; Size
dd 0x00000000                  ; Reserved

powershell_start:
    ; PowerShell initialization
    ret

powershell_end:
    db 'END', 0, 0, 0         ; End marker
