; =============================================================================
; REGEDIT.EXE - KSDOS Registry Editor
; Windows registry editing tool
; =============================================================================

org 0x1000

; ---- REGEDIT header ----
db 'REG ', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd regedit_start               ; Entry point
dd regedit_end - regedit_start  ; Size
dd 0x00000000                  ; Reserved

regedit_start:
    ; Registry Editor initialization
    ret

regedit_end:
    db 'END', 0, 0, 0         ; End marker
