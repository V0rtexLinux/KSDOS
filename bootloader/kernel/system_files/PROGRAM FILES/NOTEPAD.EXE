; =============================================================================
; NOTEPAD.EXE - KSDOS Text Editor
; Simple text editor application for KSDOS
; =============================================================================

org 0x1000

; ---- NOTEPAD header ----
db 'NOTE', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd notepad_start               ; Entry point
dd notepad_end - notepad_start  ; Size
dd 0x00000000                  ; Reserved

notepad_start:
    ; Notepad application initialization
    ret

notepad_end:
    db 'END', 0, 0, 0         ; End marker
