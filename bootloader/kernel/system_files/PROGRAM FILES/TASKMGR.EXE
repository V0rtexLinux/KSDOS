; =============================================================================
; TASKMGR.EXE - KSDOS Task Manager
; Process and system performance monitor
; =============================================================================

org 0x1000

; ---- TASKMGR header ----
db 'TASK', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd taskmgr_start               ; Entry point
dd taskmgr_end - taskmgr_start  ; Size
dd 0x00000000                  ; Reserved

taskmgr_start:
    ; Task Manager initialization
    ret

taskmgr_end:
    db 'END', 0, 0, 0         ; End marker
