; =============================================================================
; DXDIAG.EXE - KSDOS DirectX Diagnostic Tool
; DirectX system information and testing utility
; =============================================================================

org 0x1000

; ---- DXDIAG header ----
db 'DXDI', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd dxdiag_start                ; Entry point
dd dxdiag_end - dxdiag_start    ; Size
dd 0x00000000                  ; Reserved

dxdiag_start:
    ; DirectX Diagnostic initialization
    ret

dxdiag_end:
    db 'END', 0, 0, 0         ; End marker
