; =============================================================================
; PAINT.EXE - KSDOS Paint Program
; Simple drawing and painting application
; =============================================================================

org 0x1000

; ---- PAINT header ----
db 'PAIN', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd paint_start                 ; Entry point
dd paint_end - paint_start      ; Size
dd 0x00000000                  ; Reserved

paint_start:
    ; Paint application initialization
    ret

paint_end:
    db 'END', 0, 0, 0         ; End marker
