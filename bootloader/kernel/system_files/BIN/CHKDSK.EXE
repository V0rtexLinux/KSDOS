; =============================================================================
; CHKDSK.EXE - KSDOS Disk Check Utility
; Disk integrity checking tool
; =============================================================================

org 0x1000

; ---- CHKDSK header ----
db 'CHKD', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd chkdsk_start                ; Entry point
dd chkdsk_end - chkdsk_start    ; Size
dd 0x00000000                  ; Reserved

chkdsk_start:
    ; Disk check utility initialization
    ret

chkdsk_end:
    db 'END', 0, 0, 0         ; End marker
