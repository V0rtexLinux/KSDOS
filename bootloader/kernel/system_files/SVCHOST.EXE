; =============================================================================
; SVCHOST.EXE - Service Host
 Generic host process for Windows services
; =============================================================================

org 0x1000

; ---- SVCHOST header ----
db 'SVCH', 0, 0, 0           ; Signature
dw 0x0200                     ; Version 2.0
dd svchost_start               ; Entry point
dd svchost_end - svchost_start  ; Size
dd 0x00000000                  ; Reserved

svchost_start:
    ; Service host initialization
    ret

svchost_end:
    db 'END', 0, 0, 0         ; End marker
